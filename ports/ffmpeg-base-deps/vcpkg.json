  "dependencies": [
    "zlib",
    "bzip2",
    "liblzma",
    "libiconv",
    "freetype",
    "fribidi",
    "fontconfig",
    "harfbuzz",
    "libass",
    "libogg",
    "libvorbis",
    "libtheora",
    "opus",
    "speex",
    "mp3lame",
    "soxr",
    "libopenmpt",
    "libilbc",
    "libmodplug",
    "dav1d",
    "aom",
    "libvpx",
    "openjpeg",
    "snappy",
    "libwebp",
    "x264",
    "x265",
    "openh264",
    "fdk-aac",
    "sdl2",
    "libxml2",
    "vulkan-headers",
    "amd-amf",
    "libvpl",
    "mfx-dispatch",
    "opencl",
    "opengl",
    "opengl-registry",
    "libsrt",
    "libssh",
    "openssl",
    "zeromq",
    "libdvdnav",
    "libdvdread",
