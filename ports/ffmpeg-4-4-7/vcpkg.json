{
  "name": "ffmpeg-4-4-7",
  "version": "4.4.7",
  "port-version": 1,
  "description": [
    "FFmpeg 4.4.7 build for MSVC (use 'static' feature for static libraries)."
  ],
  "homepage": "https://ffmpeg.org",
  "license": null,
  "dependencies": [
    {
      "name": "vcpkg-cmake-get-vars",
      "host": true
    },
    {
      "name": "vcpkg-pkgconfig-get-modules",
      "host": true
    },
    {
      "name": "ffmpeg-builder",
      "host": true
    }
  ],
  "features": {
    "amf": {
      "description": "AMD AMF codec support",
      "dependencies": [
        "amd-amf"
      ]
    },
    "aom": {
      "description": "AV1 video encoding/decoding via libaom support in ffmpeg",
      "dependencies": [
        "aom"
      ]
    },
    "ass": {
      "description": "Libass subtitles rendering, needed for subtitles and ass filter support in ffmpeg",
      "dependencies": [
        "libass"
      ]
    },
    "avcodec": {
      "description": "Build the avcodec library"
    },
    "avdevice": {
      "description": "Build the avdevice library"
    },
    "avfilter": {
      "description": "Build the avfilter library"
    },
    "avformat": {
      "description": "Build the avformat library"
    },
    "avresample": {
      "description": "Build the avresample library"
    },
    "bluray": {
      "description": "Blu-ray disc support via libbluray",
      "dependencies": [
        "libbluray"
      ]
    },
    "bzip2": {
      "description": "Bzip2 support",
      "dependencies": [
        "bzip2"
      ]
    },
    "d3d11va": {
      "description": "Direct3D 11 Video Acceleration"
    },
    "dav1d": {
      "description": "AV1 decoding via libdav1d",
      "dependencies": [
        "dav1d"
      ]
    },
    "dxva2": {
      "description": "DXVA2 hardware decoding"
    },
    "fdk-aac": {
      "description": "AAC de/encoding via libfdk-aac",
      "dependencies": [
        "fdk-aac",
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "license-nonfree"
          ]
        }
      ]
    },
    "fontconfig": {
      "description": "Useful for drawtext filter",
      "dependencies": [
        "fontconfig"
      ]
    },
    "freetype": {
      "description": "Needed for drawtext filter",
      "dependencies": [
        "freetype"
      ]
    },
    "fribidi": {
      "description": "Improves drawtext filter",
      "dependencies": [
        "fribidi"
      ]
    },
    "gme": {
      "description": "Video game music file de/encoding via libgme",
      "dependencies": [
        "libgme"
      ]
    },
    "iconv": {
      "description": "Iconv support",
      "dependencies": [
        "libiconv"
      ]
    },
    "ilbc": {
      "description": "iLBC de/encoding via libilbc",
      "dependencies": [
        "libilbc"
      ]
    },
    "lensfun": {
      "description": "Lens correction via lensfun",
      "dependencies": [
        "lensfun"
      ]
    },
    "license-gpl": {
      "description": "Allow use of GPL code, the resulting libs and binaries will be under GPL"
    },
    "license-nonfree": {
      "description": "Allow use of nonfree code, the resulting libs and binaries will be unredistributable"
    },
    "lzma": {
      "description": "lzma support",
      "dependencies": [
        "liblzma"
      ]
    },
    "mediafoundation": {
      "description": "Media Foundation support"
    },
    "mfx": {
      "description": "Intel QSV Codec via libmfx (pre-8.0)",
      "dependencies": [
        "mfx-dispatch"
      ]
    },
    "modplug": {
      "description": "ModPlug via libmodplug",
      "dependencies": [
        "libmodplug"
      ]
    },
    "mp3lame": {
      "description": "MP3 encoding via libmp3lame",
      "dependencies": [
        "mp3lame"
      ]
    },
    "mysofa": {
      "description": "Spatial audio via libmysofa",
      "dependencies": [
        "libmysofa"
      ]
    },
    "nvcodec": {
      "description": "Nvidia video decoding/encoding acceleration",
      "dependencies": [
        "ffnvcodec-11"
      ]
    },
    "opencl": {
      "description": "OpenCL processing",
      "dependencies": [
        "opencl"
      ]
    },
    "opengl": {
      "description": "OpenGL rendering",
      "dependencies": [
        "opengl"
      ]
    },
    "openh264": {
      "description": "H.264 de/encoding via openh264",
      "dependencies": [
        "openh264"
      ]
    },
    "openjpeg": {
      "description": "JPEG 2000 de/encoding via OpenJPEG",
      "dependencies": [
        "openjpeg"
      ]
    },
    "openmpt": {
      "description": "Decoding tracked files via libopenmpt",
      "dependencies": [
        "libopenmpt"
      ]
    },
    "openssl": {
      "description": "Use OpenSSL for TLS support",
      "dependencies": [
        "openssl"
      ]
    },
    "opus": {
      "description": "Opus de/encoding via libopus",
      "dependencies": [
        "opus"
      ]
    },
    "postproc": {
      "description": "Build the postproc library",
      "dependencies": [
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "license-gpl"
          ]
        }
      ]
    },
    "pthreads": {
      "description": "POSIX threads support"
    },
    "sdl2": {
      "description": "Sdl2 support",
      "dependencies": [
        "sdl2"
      ]
    },
    "snappy": {
      "description": "Snappy compression, needed for hap encoding",
      "dependencies": [
        "snappy"
      ]
    },
    "soxr": {
      "description": "Include libsoxr resampling",
      "dependencies": [
        "soxr"
      ]
    },
    "speex": {
      "description": "Speex de/encoding via libspeex",
      "dependencies": [
        "speex"
      ]
    },
    "srt": {
      "description": "Haivision SRT protocol",
      "dependencies": [
        "libsrt"
      ]
    },
    "ssh": {
      "description": "SFTP protocol via libssh",
      "dependencies": [
        "libssh"
      ]
    },
    "static": {
      "description": "Build FFmpeg as static libraries instead of shared"
    },
    "svtav1": {
      "description": "AV1 encoding via SVT-AV1",
      "dependencies": [
        "svt-av1"
      ]
    },
    "swresample": {
      "description": "Build the swresample library"
    },
    "swscale": {
      "description": "Build the swscale library"
    },
    "tesseract": {
      "description": "Optical character recognition via tesseract",
      "dependencies": [
        "tesseract"
      ]
    },
    "theora": {
      "description": "Theora encoding via libtheora",
      "dependencies": [
        "libtheora"
      ]
    },
    "vorbis": {
      "description": "Vorbis en/decoding via libvorbis, native implementation exists",
      "dependencies": [
        "libvorbis"
      ]
    },
    "vpx": {
      "description": "VP8 and VP9 de/encoding via libvpx",
      "dependencies": [
        "libvpx"
      ]
    },
    "w32threads": {
      "description": "Windows thread support"
    },
    "webp": {
      "description": "WebP encoding via libwebp",
      "dependencies": [
        "libwebp"
      ]
    },
    "x264": {
      "description": "H.264 encoding via x264",
      "dependencies": [
        "x264",
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "license-gpl"
          ]
        }
      ]
    },
    "x265": {
      "description": "HEVC encoding via x265",
      "dependencies": [
        "x265",
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "license-gpl"
          ]
        }
      ]
    },
    "xml2": {
      "description": "XML parsing using the C library libxml2, needed for dash demuxing support",
      "dependencies": [
        "libxml2"
      ]
    },
    "zlib": {
      "description": "zlib support",
      "dependencies": [
        "zlib"
      ]
    },
    "zmq": {
      "description": "Enable ZeroMQ support",
      "dependencies": [
        "zeromq"
      ]
    },
    "all": {
      "description": "all feature group",
      "dependencies": [
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "lgpl"
          ]
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "windows-hw"
          ]
        }
      ]
    },
    "all-gpl": {
      "description": "all-gpl feature group",
      "dependencies": [
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "all"
          ]
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "gpl"
          ]
        }
      ]
    },
    "all-lgpl": {
      "description": "all-lgpl feature group",
      "dependencies": [
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "all"
          ]
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "lgpl"
          ]
        }
      ]
    },
    "all-nonfree": {
      "description": "all-nonfree feature group",
      "dependencies": [
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "all"
          ]
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "gpl"
          ]
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "lgpl"
          ]
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "nonfree"
          ]
        }
      ]
    },
    "gpl": {
      "description": "gpl feature group",
      "dependencies": [
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "postproc",
            "x264"
          ]
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "x265"
          ],
          "platform": "!uwp & !xbox"
        }
      ]
    },
    "lgpl": {
      "description": "lgpl feature group",
      "dependencies": [
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "amf",
            "ass",
            "bzip2",
            "dav1d",
            "freetype",
            "gme",
            "iconv",
            "ilbc",
            "lzma",
            "mp3lame",
            "mysofa",
            "openh264",
            "openjpeg",
            "openmpt",
            "openssl",
            "opus",
            "sdl2",
            "snappy",
            "soxr",
            "speex",
            "theora",
            "vorbis",
            "vpx",
            "webp",
            "xml2",
            "zlib"
          ]
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "lensfun"
          ],
          "platform": "!arm"
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "aom",
            "fontconfig",
            "fribidi",
            "modplug",
            "opencl",
            "tesseract"
          ],
          "platform": "!uwp"
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "nvcodec"
          ],
          "platform": "!uwp & !arm & !arm64"
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "bluray",
            "opengl",
            "srt",
            "ssh",
            "zmq"
          ],
          "platform": "!uwp & !xbox"
        },
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "svtav1"
          ],
          "platform": "!x86 & !arm32 & !uwp"
        }
      ]
    },
    "nonfree": {
      "description": "nonfree feature group",
      "dependencies": [
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "fdk-aac"
          ]
        }
      ]
    },
    "windows-hw": {
      "description": "windows-hw feature group",
      "dependencies": [
        {
          "name": "ffmpeg-4-4-7",
          "features": [
            "d3d11va",
            "dxva2",
            "mediafoundation",
            "w32threads"
          ]
        }
      ]
    }
  },
  "default-features": [
    "avcodec",
    "avdevice",
    "avfilter",
    "avformat",
    "swresample",
    "swscale"
  ]
}
