      "description": "Enable zlib support"
    },
    "zmq": {
      "description": "Enable zmq support"
    },
    "gpl": {
      "description": "GPL license build — includes x264, x265",
      "dependencies": [
        {
          "name": "ffmpeg-7-1-1-static",
          "features": [
            "x264",
            "x265"
          ]
        }
      ]
    },
    "nonfree": {
      "description": "Non-free license build — includes fdk-aac",
      "dependencies": [
        {
          "name": "ffmpeg-7-1-1-static",
          "features": [
            "gpl",
            "fdk-aac"
          ]
