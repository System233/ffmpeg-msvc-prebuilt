{
  "name": "ffmpeg-7-1-1-static",
  "version": "7.1.1",
  "port-version": 0,
  "description": [
    "FFmpeg 7.1.1 static build for MSVC.",
    "All codec dependencies are provided by ffmpeg-base-deps virtual port."
  ],
  "homepage": "https://ffmpeg.org",
  "license": null,
  "dependencies": [
    {
      "name": "ffmpeg-base-deps"
    },
    {
      "name": "vcpkg-cmake-get-vars",
      "host": true
    },
    {
      "name": "vcpkg-pkgconfig-get-modules",
      "host": true
    },
    {
      "name": "ffnvcodec"
    }
  ],
  "features": {
    "amf": {
      "description": "Enable amf support"
