[binaries]
c = 'cl'
cpp = 'cl'
ar = 'lib'
as = '@CMAKE_ASM_COMPILER@'
pkg-config = 'pkg-config'
cmake = 'cmake'
gas-preprocessor.pl = ['perl', '@CMAKE_CURRENT_LIST_DIR@/cmake/gas-preprocessor.pl']

[properties]
has_function_printf = true
sys_root = '@STAGE_DIR@'
pkg_config_libdir = '@STAGE_DIR@/lib/pkgconfig;@STAGE_DIR@/share/pkgconfig'

[built-in options]
c_link_args = ['/LIBPATH:@STAGE_DIR@/lib']
pkg_config_path = '@STAGE_DIR@/lib/pkgconfig;@STAGE_DIR@/share/pkgconfig'
b_vscrt='mt'
buildtype = 'debugoptimized'
default_library = 'static'
vsenv = true

[host_machine]
system = 'windows'
cpu_family = '@MESON_CPU_FAMILY@'
cpu = '@MESON_CPU@'
endian = 'little'
