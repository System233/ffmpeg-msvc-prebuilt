<script setup lang="ts">
import { useData, withBase } from 'vitepress'
import { ref, watchEffect, computed, nextTick } from 'vue'
import { Icon } from '@iconify/vue'
import SiteFooter from './SiteFooter.vue'
import TooltipTag from './TooltipTag.vue'
import ScrollToTop from './ScrollToTop.vue'
import { GITHUB_REPO_URL } from '../constants'
import { compDesc } from '../descriptions'

const { params, localeIndex } = useData()

const release = ref<any>(null)
const error = ref(false)

// Filters for metadata section (Single-select with toggle)
const selectedArch = ref<string | null>(null)
const selectedLinkage = ref<string | null>(null)
const selectedLicense = ref<string | null>(null)
const variantSearch = ref('')
const copiedVariantId = ref('')
let copyTimer: ReturnType<typeof setTimeout> | null = null

const highlightedVariant = ref('')
let highlightTimer: ReturnType<typeof setTimeout> | null = null

const expandedVariantId = ref<string | null>(null)

function toggleVariantExpanded(id: string) {
  expandedVariantId.value = expandedVariantId.value === id ? null : id
}

function scrollToVariant(id: string) {
  expandedVariantId.value = id
  nextTick(() => {
    const el = document.getElementById(id)
    if (el) {
      el.scrollIntoView({ behavior: 'smooth', block: 'center' })
      highlightedVariant.value = id
      if (highlightTimer) clearTimeout(highlightTimer)
      highlightTimer = setTimeout(() => { highlightedVariant.value = '' }, 2000)
    }
  })
}

// Tooltip data from localization
const tooltipMap: Record<string, string> = {
  x64: "[[release.tooltips.x64]]",
  x86: "[[release.tooltips.x86]]",
  arm64: "[[release.tooltips.arm64]]",
  arm: "[[release.tooltips.arm32]]",
  shared: "[[release.tooltips.shared]]",
  static: "[[release.tooltips.static]]",
  gpl: "[[release.tooltips.gpl]]",
  lgpl: "[[release.tooltips.lgpl]]",
  nonfree: "[[release.tooltips.nonfree]]"
}

// Use dynamic import to load data based on params.id
watchEffect(async () => {
  const id = params.value?.id
  if (!id) return

  try {
    const modules: any = import.meta.glob('../../.vitepress/generated/releases/*.ts')
    const path = `../../.vitepress/generated/releases/${id}.ts`
    const loader = modules[path]
    
    if (loader) {
      const mod = await loader()
      release.value = mod.default
      error.value = false
    } else {
      error.value = true
    }
  } catch (err) {
    console.error('Failed to load release data:', err)
    error.value = true
  }
})

const filteredVariants = computed(() => {
  if (!release.value?.variants) return []
  const q = variantSearch.value.toLowerCase()
  return release.value.variants.filter((v: any) => {
    if (q) {
      const inFile = v.assets.binary.file.toLowerCase().includes(q)
      const inFeat = v.features?.some((f: string) => f.toLowerCase().includes(q))
      const inDep  = v.dependencies?.some((d: string) => d.toLowerCase().includes(q))
      if (!inFile && !inFeat && !inDep) return false
    }
    if (selectedArch.value && v.arch !== selectedArch.value) return false
    if (selectedLinkage.value && v.linkage !== selectedLinkage.value) return false
    if (selectedLicense.value && v.license !== selectedLicense.value) return false
    return true
  })
})

const archOrder: Record<string, number> = { x64: 0, x86: 1, arm64: 2, arm: 3 }

const availableArchs = computed(() => {
  const a = [...new Set(release.value?.variants?.map((v: any) => v.arch) || [])] as string[]
  return a.sort((a, b) => (archOrder[a] ?? 99) - (archOrder[b] ?? 99))
})
const linkages = computed(() => {
  const l = [...new Set(release.value?.variants?.map((v: any) => v.linkage) || [])] as string[]
  return l.sort()
})
const licenses = computed(() => {
  const lic = [...new Set(release.value?.variants?.map((v: any) => v.license) || [])] as string[]
  return lic.sort()
})

function toggleArch(val: string) { selectedArch.value = selectedArch.value === val ? null : val }
function toggleLinkage(val: string) { selectedLinkage.value = selectedLinkage.value === val ? null : val }
function toggleLicense(val: string) { selectedLicense.value = selectedLicense.value === val ? null : val }
function searchVariant(q: string) { variantSearch.value = q }

function fmtSize(b: number): string {
  if (!b) return '—'
  if (b >= 1e9) return (b / 1e9).toFixed(1) + ' GB'
  if (b >= 1e6) return (b / 1e6).toFixed(1) + ' MB'
  return (b / 1024).toFixed(1) + ' KB'
}

function developDownloadUrl(v: any): string | undefined {
  return v.develop_download_url
}

function fmtDate(iso: string): string {
  if (!iso) return ''
  return new Date(iso).toLocaleDateString(undefined, {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  })
}

const archLabel: Record<string, string> = { x64: 'x64', x86: 'x86', arm64: 'ARM64', arm: 'ARM32' }
const allCombos = ['shared-gpl', 'shared-lgpl', 'static-gpl', 'static-lgpl']

function getCombos() {
  if (!release.value?.variants) return []
  return allCombos.filter(c => {
    const [link, lic] = c.split('-')
    return release.value.variants.some((v: any) => v.linkage === link && v.license === lic)
  })
}

function getV(arch: string, linkage: string, license: string): any {
  return release.value?.variants?.find((v: any) =>
    v.arch === arch && v.linkage === linkage && v.license === license
  )
}

function cellAt(arch: string, combo: string): any {
  const [link, lic] = combo.split('-')
  return getV(arch, link, lic)
}

function colLabel(c: string): string {
  const [link, lic] = c.split('-')
  return `${link === 'shared' ? '[[variant.shared]]' : '[[variant.static]]'} ${lic.toUpperCase()}`
}

function getComboTooltip(c: string): string {
  const [link, lic] = c.split('-')
  return `${tooltipMap[link]} • ${tooltipMap[lic]}`
}

function copyText(digest: string, id: string) {
  const hash = digest.includes(':') ? digest.split(':').slice(1).join(':') : digest
  navigator.clipboard.writeText(hash)
  copiedVariantId.value = id
  if (copyTimer) clearTimeout(copyTimer)
  copyTimer = setTimeout(() => { copiedVariantId.value = '' }, 1500)
}

function variantId(file: string): string {
  return 'v-' + file.replace(/\.zip$/, '').replace(/[^a-zA-Z0-9_-]/g, '_')
}

const FFMPEG_REPO = 'https://github.com/FFmpeg/FFmpeg'

function ffmpegRefUrl(ref: string): string | null {
  if (!ref) return null
  const commitMatch = ref.match(/-g([a-f0-9]+)$/)
  if (commitMatch) return `${FFMPEG_REPO}/commit/${commitMatch[1]}`
  return `${FFMPEG_REPO}/releases/tag/${ref}`
}
</script>

<template>
<div v-if="release" class="space-y-12">
  <!-- Header -->
  <header class="space-y-6">
    <div class="flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-gray-500">
      <a :href="withBase(`/${localeIndex}/releases`)" class="font-bold hover:text-blue-600 transition-colors no-underline">[[release.backToList]]</a>
      <Icon icon="fa6-solid:chevron-right" class="text-xs" />
      <span class="text-gray-900 dark:text-white font-bold">{{ release.version }}</span>
    </div>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
      <div class="flex flex-wrap items-center gap-4">
        <h1 class="text-3xl font-bold tracking-tight m-0 text-gray-900 dark:text-white">
        FFmpeg {{ release.version }}
        <TooltipTag :tooltip="'[[release.tooltips.revision]]'"><span class=" text-gray-500">#{{release.revision}}</span></TooltipTag>
        </h1>
        <div class="flex items-center gap-2">
          <span v-if="release.lts" class="badge badge-green">[[release.lts]]</span>
          <span v-if="release.snapshot" class="badge badge-blue">[[release.master]]</span>
          <!-- <span class="badge badge-outline">r{{ release.revision }}</span> -->
        </div>
      </div>
      <a v-if="release.release_url" :href="release.release_url" target="_blank" class="btn-secondary h-8 px-3 text-xs gap-2 font-bold">
        <Icon icon="fa6-brands:github" />
        [[release.viewOnGitHub]]
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-4 border-t border-gray-100 dark:border-gray-800">
      <div class="space-y-1">
        <span class="text-xs font-bold uppercase tracking-widest text-gray-400">[[release.releasedOn]]</span>
        <div class="text-xs text-gray-600 dark:text-gray-400 font-medium">{{ fmtDate(release.created) }}</div>
      </div>
      <div class="space-y-1">
        <span class="text-xs font-bold uppercase tracking-widest text-gray-400">[[release.ffmpegRef]]</span>
        <div class="text-xs font-mono text-gray-600 dark:text-gray-400 truncate">
          <a v-if="release.ffmpeg_ref" :href="ffmpegRefUrl(release.ffmpeg_ref)" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline no-underline font-bold">
            {{ release.ffmpeg_ref }}
            <Icon icon="fa6-solid:arrow-up-right-from-square" class="text-xs inline-block ml-0.5" />
          </a>
          <span v-else>—</span>
        </div>
      </div>
      <div class="space-y-1">
        <span class="text-xs font-bold uppercase tracking-widest text-gray-400">[[release.progress]]</span>
        <div class="text-xs font-bold text-gray-700 dark:text-gray-300">
          <TooltipTag :tooltip="'[[release.tooltips.progress]]'">
            <span :class="release.complete ? 'text-green-600' : 'text-amber-600'">{{ release.variant_count }} / {{ release.total_variants }}</span>
          </TooltipTag>
        </div>
      </div>
      <div class="space-y-1">
        <span class="text-xs font-bold uppercase tracking-widest text-gray-400">[[release.releaseTag]]</span>
        <div class="text-xs text-gray-600 dark:text-gray-400 truncate">
          <a :href="GITHUB_REPO_URL + '/releases/tag/' + release.release_tag" target="_blank" class="text-blue-600 dark:text-blue-400 hover:underline no-underline font-bold">
            {{ release.release_tag }}
            <Icon icon="fa6-solid:arrow-up-right-from-square" class="text-xs inline-block ml-0.5" />
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Download Matrix -->
  <section class="space-y-4">
    <h2 class="text-xl font-bold tracking-tight text-gray-900 dark:text-white">[[variant.download]]</h2>
    <div class="overflow-x-auto">
      <table class="border-none">
        <thead class="bg-gray-50/50 dark:bg-gray-800/30">
          <tr>
            <th class="w-32 py-2">[[release.architectures]]</th>
            <th v-for="c in getCombos()" :key="c" class="text-center! py-2">
              <TooltipTag :tooltip="getComboTooltip(c)">
                <div class="inline-flex items-center gap-1.5">
                  {{ colLabel(c) }}
                </div>
              </TooltipTag>
            </th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="arch in availableArchs" :key="arch">
            <td class="font-bold text-gray-900 dark:text-white uppercase text-xs py-3 whitespace-nowrap">
              <TooltipTag :tooltip="tooltipMap[arch]">
                <div class="flex items-center gap-2">
                  <Icon icon="fa6-solid:microchip" class="text-gray-300" />
                  {{ archLabel[arch] || arch }}
                </div>
              </TooltipTag>
            </td>
            <td v-for="c in getCombos()" :key="c" class="text-center! py-2">
              <template v-if="cellAt(arch, c)">
                <div class="inline-flex items-start gap-2">
                  <div class="flex flex-col items-end gap-1">
                    <TooltipTag :tooltip="'[[variant.tooltip.binary]]'">
                      <a :href="cellAt(arch, c).download_url" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 font-bold text-xs whitespace-nowrap no-underline! inline-flex items-center gap-1">
                        <Icon icon="fa6-solid:download" class="text-xs" />
                        {{ fmtSize(cellAt(arch, c).assets.binary.size) }}
                      </a>
                    </TooltipTag>
                    <TooltipTag v-if="cellAt(arch, c).assets.develop && developDownloadUrl(cellAt(arch, c))" :tooltip="'[[variant.tooltip.develop]]'">
                      <a :href="developDownloadUrl(cellAt(arch, c))" class="text-blue-500/70 dark:text-blue-400/70 hover:text-blue-600 dark:hover:text-blue-400 font-bold text-xs whitespace-nowrap no-underline! inline-flex items-center gap-1">
                        <Icon icon="fa6-solid:cube" class="text-xs" />
                        {{ fmtSize(cellAt(arch, c).assets.develop?.size) }}
                      </a>
                    </TooltipTag>
                  </div>
                  <TooltipTag :tooltip="'[[variant.tooltip.viewDetails]]'">
                    <button @click="scrollToVariant(variantId(cellAt(arch, c).assets.binary.file))" class="mt-0.5 inline-flex items-center justify-center w-4 h-4 rounded-full border border-gray-300 dark:border-gray-600 hover:border-blue-500 dark:hover:border-blue-400 text-gray-400 hover:text-blue-500 dark:hover:text-blue-400 transition-colors cursor-pointer shrink-0">
                      <Icon icon="fa6-solid:chevron-down" class="text-xs" />
                    </button>
                  </TooltipTag>
                </div>
              </template>
              <span v-else class="text-gray-200 dark:text-gray-800">—</span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Detailed Metadata -->
  <section class="space-y-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-gray-100 dark:border-gray-800 pb-4">
      <div class="space-y-1">
        <h2 class="text-xl font-bold tracking-tight m-0 text-gray-900 dark:text-white">[[release.metadata]]</h2>
        <span class="text-xs font-medium uppercase tracking-widest text-gray-400">{{ filteredVariants.length }} / {{ release.variants?.length }} [[release.available]]</span>
      </div>
      
      <!-- Metadata Filters -->
      <div class="flex flex-col gap-2 max-w-full">
        <!-- Search -->
        <div class="flex items-center gap-1.5 self-end">
          <Icon icon="fa6-solid:magnifying-glass" class="text-gray-400 text-xs shrink-0" />
          <input v-model="variantSearch" type="text" :placeholder="'[[release.variantSearch]]'"
            class="w-full sm:w-[200px] px-2 py-1.5 rounded border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#0c0c0e] text-xs placeholder:text-gray-400 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 outline-none transition-all dark:text-white" />
        </div>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2">
          <!-- Arch Filter -->
          <div class="flex items-center gap-1.5">
            <span class="text-xs font-bold uppercase tracking-widest text-gray-400 shrink-0">[[release.architectures]]</span>
            <div class="flex flex-wrap gap-1.5">
              <TooltipTag v-for="a in availableArchs" :key="a" :tooltip="tooltipMap[a]">
                <button @click="toggleArch(a)"
                  class="badge uppercase cursor-pointer"
                  :class="selectedArch === a ? 'badge-purple ring-2 ring-purple-400' : 'badge-outline hover:border-purple-400'">
                  {{ a }}
                </button>
              </TooltipTag>
            </div>
          </div>
          <!-- Linkage Filter -->
          <div class="flex items-center gap-1.5">
            <span class="text-xs font-bold uppercase tracking-widest text-gray-400 shrink-0">[[release.linkages]]</span>
            <div class="flex flex-wrap gap-1.5">
              <TooltipTag v-for="l in linkages" :key="l" :tooltip="tooltipMap[l]">
                <button @click="toggleLinkage(l)"
                  class="badge lowercase cursor-pointer"
                  :class="selectedLinkage === l ? 'badge-blue ring-2 ring-blue-400' : 'badge-outline hover:border-blue-400'">
                  {{ l }}
                </button>
              </TooltipTag>
            </div>
          </div>
          <!-- License Filter -->
          <div class="flex items-center gap-1.5">
            <span class="text-xs font-bold uppercase tracking-widest text-gray-400 shrink-0">[[release.licenses]]</span>
            <div class="flex flex-wrap gap-1.5">
              <TooltipTag v-for="l in licenses" :key="l" :tooltip="tooltipMap[l]">
                <button @click="toggleLicense(l)"
                  class="badge uppercase cursor-pointer"
                  :class="selectedLicense === l ? 'badge-amber ring-2 ring-amber-400' : 'badge-outline hover:border-amber-400'">
                  {{ l }}
                </button>
              </TooltipTag>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="border border-gray-200 dark:border-gray-800 rounded-md max-w-full">
      <div v-for="(v, idx) in filteredVariants" :key="v.assets.binary.file" :id="variantId(v.assets.binary.file)"
        class="transition-all cursor-pointer select-none"
        :class="[
          idx < filteredVariants.length - 1 ? 'border-b border-gray-100 dark:border-gray-800' : '',
          highlightedVariant === variantId(v.assets.binary.file) ? 'ring-2 ring-blue-400/50 bg-blue-50/40 dark:bg-blue-900/10' : ''
        ]"
        @click="toggleVariantExpanded(variantId(v.assets.binary.file))">

        <!-- Compact Row (always visible) -->
        <div class="flex items-center gap-1 sm:gap-2 min-w-0 px-3 py-3 hover:bg-gray-50/50 dark:hover:bg-gray-800/20">
          <Icon icon="fa6-solid:chevron-right"
            class="text-xs w-3 shrink-0 text-gray-400 transition-transform duration-200"
            :class="expandedVariantId === variantId(v.assets.binary.file) ? 'rotate-90' : ''" />
          <span class="hidden sm:inline text-sm font-mono font-bold text-gray-600 dark:text-gray-300 truncate max-w-[120px] shrink-0">{{ release.version }}</span>
          <span class="hidden sm:inline"><Icon icon="fa6-solid:circle" class="text-xs shrink-0 text-gray-300 dark:text-gray-600" /></span>
          <span class="text-xs sm:text-sm font-mono font-bold text-purple-500 dark:text-purple-400 truncate min-w-0">{{ v.triplet }}</span>
          <span class="text-xs sm:text-sm font-mono font-medium text-blue-500 dark:text-blue-400 lowercase shrink-0">{{ v.linkage }}</span>
          <span class="text-xs sm:text-sm font-mono font-medium text-amber-500 dark:text-amber-400 uppercase shrink-0">{{ v.license }}</span>
          <div class="ml-auto flex items-center gap-3 sm:gap-5 shrink-0">
            <TooltipTag :tooltip="'[[variant.tooltip.binary]]'">
              <a :href="v.download_url" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 text-sm font-bold whitespace-nowrap no-underline!" @click.stop>
                <Icon icon="fa6-solid:download" class="text-sm" />
                <span class="ml-1">{{ fmtSize(v.assets.binary.size) }}</span>
              </a>
            </TooltipTag>
            <TooltipTag v-if="v.assets.develop && developDownloadUrl(v)" :tooltip="'[[variant.tooltip.develop]]'">
              <a :href="developDownloadUrl(v)" class="text-gray-400 dark:text-gray-500 hover:text-gray-600 text-sm font-bold whitespace-nowrap no-underline!" @click.stop>
                <Icon icon="fa6-solid:cube" class="text-sm" />
                <span class="ml-1">{{ fmtSize(v.assets.develop.size) }}</span>
              </a>
            </TooltipTag>
          </div>
        </div>

        <!-- Expanded Content -->
        <div class="transition-all duration-300 ease-out overflow-hidden"
          :style="{ display: 'grid', gridTemplateRows: expandedVariantId === variantId(v.assets.binary.file) ? '1fr' : '0fr' }">
          <div class="min-h-0" @click.stop>

            <!-- Features & Dependencies -->
            <div class="space-y-4 px-3 pb-4">
              <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                <div class="lg:col-span-6 space-y-3">
                  <div class="text-sm font-bold uppercase tracking-widest text-gray-900 dark:text-gray-100 flex items-center gap-1.5">
                    <Icon icon="fa6-solid:wand-magic-sparkles" class="text-indigo-500" />
                    [[variant.features]]
                  </div>
                  <div v-if="v.features?.length" class="flex flex-wrap gap-1">
                    <TooltipTag v-for="f in v.features" :key="f" :tooltip="compDesc[f] || f">
                      <span @click.stop="searchVariant(f)" class="px-1.5 py-0.5 text-xs font-medium badge-indigo border border-indigo-200/30 dark:border-indigo-800/30 rounded cursor-pointer">
                        {{ f }}
                      </span>
                    </TooltipTag>
                  </div>
                  <div v-else class="text-xs text-gray-400 italic font-medium">[[release.noFeatures]]</div>
                </div>
                <div class="lg:col-span-6 space-y-3">
                  <div class="text-sm font-bold uppercase tracking-widest text-gray-900 dark:text-gray-100 flex items-center gap-1.5">
                    <Icon icon="fa6-solid:link" class="text-amber-500" />
                    [[variant.dependencies]]
                  </div>
                  <div v-if="v.dependencies?.length" class="flex flex-wrap gap-1">
                    <TooltipTag v-for="d in v.dependencies" :key="d" :tooltip="compDesc[d] || d">
                      <span @click.stop="searchVariant(d)" class="px-1.5 py-0.5 text-xs font-medium badge-amber border border-amber-200/30 dark:border-amber-800/30 rounded cursor-pointer">
                        {{ d }}
                      </span>
                    </TooltipTag>
                  </div>
                  <div v-else class="text-xs text-gray-400 italic font-medium">[[release.noDeps]]</div>
                </div>
              </div>

              <!-- Checksum -->
              <div class="flex items-center gap-3 pt-3 border-t border-gray-100 dark:border-gray-800">
                <TooltipTag :tooltip="'[[release.tooltips.hash]]'">
                  <span class="font-mono text-xs font-bold text-gray-400 uppercase tracking-wider">{{ (v.assets.binary.digest || ':').split(':')[0].toUpperCase() }}</span>
                </TooltipTag>
                <code class="flex-1 text-xs font-mono text-gray-400 truncate">{{ (v.assets.binary.digest || ':').split(':').slice(1).join(':') }}</code>
                <div class="relative">
                  <button @click="copyText(v.assets.binary.digest, v.assets.binary.file)" class="text-blue-600 dark:text-blue-400 hover:text-blue-700 shrink-0 cursor-pointer" :title="'[[release.copyHash]]'">
                    <Icon icon="fa6-solid:copy" class="text-xs" />
                  </button>
                  <span v-if="copiedVariantId === v.assets.binary.file" class="absolute -top-7 right-0 whitespace-nowrap bg-gray-800 dark:bg-gray-700 text-gray-100 text-xs px-2 py-0.5 rounded shadow-lg z-50 pointer-events-none">
                    [[release.copied]]
                  </span>
                </div>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <SiteFooter class="mt-auto" />
  <ScrollToTop />
</div>

<div v-else-if="error" class="text-center py-32 space-y-4">
  <Icon icon="fa6-solid:triangle-exclamation" class="text-3xl text-gray-200 mx-auto" />
  <h3 class="text-lg font-bold text-gray-900 dark:text-white m-0">[[release.notFound]]</h3>
  <a :href="withBase(`/${localeIndex}/releases`)" class="btn-primary">[[release.backToCatalog]]</a>
</div>

<div v-else class="py-32 flex flex-col items-center justify-center space-y-2">
  <div class="w-4 h-4 border-2 border-blue-600 border-t-transparent rounded-full animate-spin"></div>
  <span class="text-xs font-bold uppercase tracking-widest text-gray-400">[[release.loading]]</span>
</div>
</template>
