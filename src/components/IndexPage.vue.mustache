<script setup lang="ts">
import { useData, withBase } from 'vitepress'
import { releasesIndex, releasesByMajor, majors } from '../../.vitepress/generated/releases-index'
import { computed } from 'vue'
import { Icon } from '@iconify/vue'
import SiteFooter from './SiteFooter.vue'
import ScrollToTop from './ScrollToTop.vue'
import TooltipTag from './TooltipTag.vue'
import { GITHUB_REPO_URL } from '../constants'

const { localeIndex } = useData()

function fmtDate(iso: string): string {
  if (!iso) return ''
  return new Date(iso).toLocaleDateString(undefined, {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  })
}

const featuredReleases = computed(() => {
  if (!releasesIndex.length) return []

  // 1. Get snapshot (latest dev build)
  const snapshot = releasesIndex.find(r => r.ffmpeg_ref.includes('-dev'))

  // 2. Per-major: pick latest release for each version family
  const perMajor = majors
    .filter(m => m !== 'master')
    .map(m => releasesByMajor[m]?.[0])
    .filter(Boolean)

  // Snapshot first, then per-major latest (deduped)
  const combined = snapshot ? [snapshot, ...perMajor] : [...perMajor]
  return Array.from(new Map(combined.map(r => [r.id, r])).values())
})

// Localized features from mustache
const localizedFeatures = [
  [[#hero.features]]
  {
    icon: '[[icon]]',
    title: '[[title]]',
    desc: '[[desc]]'
  },
  [[/hero.features]]
]
</script>

<template>
<div class="space-y-24">
  <!-- Hero Section -->
  <section class="flex flex-col items-center text-center space-y-8 pt-20">
    <div class="space-y-4">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight m-0! text-gray-900 dark:text-white">[[hero.title]]</h1>
      <p class="text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed font-medium">
        [[hero.subtitle]]
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-2">
      <a href="https://github.com/System233/ffmpeg-msvc-prebuilt/actions/workflows/build-release.yml" target="_blank">
        <img src="https://img.shields.io/github/actions/workflow/status/System233/ffmpeg-msvc-prebuilt/build-release.yml?label=Build&logo=github" alt="Build" class="h-7" />
      </a>
      <a href="https://github.com/System233/ffmpeg-msvc-prebuilt/actions/workflows/master-build.yml" target="_blank">
        <img src="https://img.shields.io/github/actions/workflow/status/System233/ffmpeg-msvc-prebuilt/master-build.yml?label=Master&logo=github" alt="Master" class="h-7" />
      </a>
      <a href="https://github.com/System233/ffmpeg-msvc-prebuilt/actions/workflows/pages.yml" target="_blank">
        <img src="https://img.shields.io/github/actions/workflow/status/System233/ffmpeg-msvc-prebuilt/pages.yml?branch=web&label=Pages&logo=github" alt="Pages" class="h-7" />
      </a>
      <a href="https://github.com/System233/ffmpeg-msvc-prebuilt/releases/latest" target="_blank">
        <img src="https://img.shields.io/github/v/release/System233/ffmpeg-msvc-prebuilt?display_name=tag&label=Release&logo=github" alt="Release" class="h-7" />
      </a>
      <a href="https://github.com/System233/ffmpeg-msvc-prebuilt/blob/main/LICENSE" target="_blank">
        <img src="https://img.shields.io/badge/license-MIT%20%2F%20GPL%20%2F%20LGPL-blue" alt="License" class="h-7" />
      </a>
      <a href="https://github.com/System233/ffmpeg-msvc-prebuilt/commits/main" target="_blank">
        <img src="https://img.shields.io/github/last-commit/System233/ffmpeg-msvc-prebuilt" alt="Last Commit" class="h-7" />
      </a>
    </div>

    <div class="flex flex-wrap justify-center gap-4">
      <a :href="withBase(`/${localeIndex}/releases`)" class="btn-primary px-8 h-12 text-base font-bold">
        [[hero.viewAll]]
      </a>
      <a :href="GITHUB_REPO_URL" target="_blank" class="btn-secondary px-8 h-12 text-base font-bold">
        <Icon icon="fa6-brands:github" class="mr-2" />
        [[hero.github]]
      </a>
    </div>
  </section>

  <!-- Featured Releases -->
  <section v-if="featuredReleases.length" class="space-y-8">
    <div class="flex items-center justify-between border-b border-gray-100 dark:border-gray-800 pb-4">
      <h2 class="text-2xl font-bold tracking-tight m-0! text-gray-900 dark:text-white">[[hero.latestTitle]]</h2>
      <a :href="withBase(`/${localeIndex}/releases`)" class="text-sm font-bold text-blue-600 dark:text-blue-400 hover:underline no-underline">[[hero.viewAll]] &rarr;</a>
    </div>

    <div class="card overflow-x-auto">
      <table class="m-0! border-none">
        <thead>
          <tr>
            <th class="w-[30%]">[[release.version]]</th>
            <th class="hidden sm:table-cell">[[release.releasedOn]]</th>
            <th class="text-center">[[release.architectures]]</th>
            <th class="text-center w-24"></th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="r in featuredReleases" :key="r.id" class="hover:bg-gray-50/50 dark:hover:bg-gray-800/20 transition-colors">
            <td>
              <div class="flex flex-col gap-1">
                <div class="flex items-center gap-2">
                  <a :href="withBase(`/${localeIndex}/releases/${r.id}`)" class="font-bold text-gray-900 dark:text-white no-underline hover:text-blue-600 transition-colors">{{ r.version }}</a>
                  <TooltipTag v-if="r.ffmpeg_ref.includes('-dev')" :tooltip="'[[release.tooltips.dev]]'"><span class="badge badge-blue">[[release.master]]</span></TooltipTag>
                  <TooltipTag v-else-if="releasesIndex.length > 0 && r.id === releasesIndex[0].id" :tooltip="'[[release.tooltips.latest]]'"><span class="badge bg-blue-600 text-white border-blue-600">Latest</span></TooltipTag>
                  <TooltipTag v-if="r.lts" :tooltip="'[[release.tooltips.lts]]'"><span class="badge badge-green">LTS</span></TooltipTag>
                </div>
                <TooltipTag :tooltip="'[[release.tooltips.revision]]'"><span class="text-xs font-mono text-gray-400 uppercase tracking-tighter">r{{ r.revision }} • {{ r.release_tag }}</span></TooltipTag>
              </div>
            </td>
            <td class="hidden sm:table-cell text-xs text-gray-500 font-medium whitespace-nowrap">{{ fmtDate(r.created) }}</td>
            <td class="text-center">
              <div class="flex flex-wrap justify-center gap-1">
                <TooltipTag v-for="a in r.archs" :key="a" :tooltip="a === 'x64' ? '[[release.tooltips.x64]]' : a === 'x86' ? '[[release.tooltips.x86]]' : a === 'arm64' ? '[[release.tooltips.arm64]]' : '[[release.tooltips.arm32]]'"><span class="badge badge-purple lowercase text-xs px-1.5 py-0">{{ a }}</span></TooltipTag>
              </div>
            </td>
            <td class="text-center">
              <a :href="withBase(`/${localeIndex}/releases/${r.id}`)" class="btn-primary h-7 px-4 text-xs font-bold mx-auto">
                [[variant.download]]
              </a>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="space-y-12">
    <h2 class="text-center text-3xl font-bold tracking-tight text-gray-900 dark:text-white font-bold">[[hero.featuresTitle]]</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div v-for="f in localizedFeatures" :key="f.title" class="space-y-4 text-center">
        <div class="inline-flex w-12 h-12 rounded-lg bg-blue-50 dark:bg-blue-900/20 items-center justify-center mx-auto md:mx-0">
          <Icon :icon="f.icon" class="text-xl text-blue-600 dark:text-blue-400" />
        </div>
        <div class="space-y-2">
          <h3 class="text-xl font-bold m-0! leading-tight" v-html="f.title"></h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed font-medium" v-html="f.desc"></p>
        </div>
      </div>
    </div>
  </section>

  <SiteFooter class="mt-auto" />
  <ScrollToTop />
</div>
</template>
