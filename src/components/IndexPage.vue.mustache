<script setup lang="ts">
import { releasesIndex } from '../../.vitepress/generated/releases-index'
import { computed } from 'vue'
import { Icon } from '@iconify/vue'
import SiteFooter from './SiteFooter.vue'
import { GITHUB_REPO_URL } from '../constants'

function fmtDate(iso: string): string {
  if (!iso) return ''
  return new Date(iso).toLocaleDateString(undefined, {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  })
}

const featuredReleases = computed(() => {
  if (!releasesIndex.length) return []
  
  // 1. Get Master
  const master = releasesIndex.find(r => r.major === 'master')
  // 2. Get Absolute Latest
  const latest = releasesIndex[0]
  // 3. Get all LTS
  const lts = releasesIndex.filter(r => r.lts)
  
  // Order: Master -> Latest -> LTS
  const combined = [master, latest, ...lts].filter((r): r is any => !!r)
  
  // Deduplicate by ID while maintaining order
  const unique = Array.from(new Map(combined.map(r => [r.id, r])).values())
  
  return unique
})

// Localized features from mustache
const localizedFeatures = [
  [[#hero.features]]
  {
    icon: '[[icon]]',
    title: '[[title]]',
    desc: '[[desc]]'
  },
  [[/hero.features]]
]
</script>

<template>
<div class="space-y-24">
  <!-- Hero Section -->
  <section class="flex flex-col items-center text-center space-y-8 pt-20">
    <div class="space-y-4">
      <h1 class="text-5xl md:text-7xl font-extrabold tracking-tight m-0! text-gray-900 dark:text-white">[[hero.title]]</h1>
      <p class="text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto leading-relaxed font-medium">
        [[hero.subtitle]]
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-4">
      <a href="./releases" class="btn-primary px-8 h-12 text-base font-bold">
        [[hero.viewAll]]
      </a>
      <a :href="GITHUB_REPO_URL" target="_blank" class="btn-secondary px-8 h-12 text-base font-bold">
        <Icon icon="fa6-brands:github" class="mr-2" />
        [[hero.github]]
      </a>
    </div>
  </section>

  <!-- Featured Releases (Unified List) -->
  <section v-if="featuredReleases.length" class="space-y-8">
    <div class="flex items-center justify-between border-b border-gray-100 dark:border-gray-800 pb-4">
      <h2 class="text-2xl font-bold tracking-tight m-0! text-gray-900 dark:text-white">[[hero.latestTitle]]</h2>
      <a href="./releases" class="text-sm font-bold text-blue-600 dark:text-blue-400 hover:underline no-underline">[[hero.viewAll]] &rarr;</a>
    </div>

    <div class="card overflow-hidden">
      <table class="m-0! border-none">
        <thead>
          <tr>
            <th class="w-[30%]">[[release.version]]</th>
            <th class="hidden sm:table-cell">[[release.releasedOn]]</th>
            <th class="hidden md:table-cell text-center">[[release.architectures]]</th>
            <th class="text-center w-24"></th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="r in featuredReleases" :key="r.id" class="hover:bg-gray-50/50 dark:hover:bg-gray-800/20 transition-colors">
            <td>
              <div class="flex flex-col gap-1">
                <div class="flex items-center gap-2">
                  <a :href="'./releases/' + r.id" class="font-bold text-gray-900 dark:text-white no-underline hover:text-blue-600 transition-colors">{{ r.version }}</a>
                  <span v-if="r.major === 'master'" class="badge badge-blue">Master</span>
                  <span v-else-if="r.id === releasesIndex[0].id" class="badge bg-blue-600 text-white border-blue-600">Latest</span>
                  <span v-if="r.lts" class="badge badge-green">LTS</span>
                </div>
                <span class="text-[10px] font-mono text-gray-400 uppercase tracking-tighter">r{{ r.revision }} • {{ r.release_tag }}</span>
              </div>
            </td>
            <td class="hidden sm:table-cell text-xs text-gray-500 font-medium whitespace-nowrap">{{ fmtDate(r.created) }}</td>
            <td class="hidden md:table-cell text-center">
              <div class="flex flex-wrap justify-center gap-1">
                <span v-for="a in r.archs" :key="a" class="badge badge-purple lowercase text-[8px] px-1.5 py-0">{{ a }}</span>
              </div>
            </td>
            <td class="text-center">
              <a :href="'./releases/' + r.id" class="btn-primary h-7 px-4 text-[10px] font-bold mx-auto">
                [[variant.download]]
              </a>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="space-y-12">
    <h2 class="text-center text-3xl font-bold tracking-tight text-gray-900 dark:text-white font-bold">[[hero.featuresTitle]]</h2>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <div v-for="f in localizedFeatures" :key="f.title" class="space-y-4 text-center">
        <div class="inline-flex w-12 h-12 rounded-lg bg-blue-50 dark:bg-blue-900/20 items-center justify-center mx-auto md:mx-0">
          <Icon :icon="f.icon" class="text-xl text-blue-600 dark:text-blue-400" />
        </div>
        <div class="space-y-2">
          <h3 class="text-xl font-bold m-0! leading-tight" v-html="f.title"></h3>
          <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed font-medium" v-html="f.desc"></p>
        </div>
      </div>
    </div>
  </section>

  <SiteFooter />
</div>
</template>
