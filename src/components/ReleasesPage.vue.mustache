<script setup lang="ts">
import { releasesIndex } from '../../.vitepress/generated/releases-index'
import { ref, computed } from 'vue'
import { useData, withBase } from 'vitepress'
import { Icon } from '@iconify/vue'
import SiteFooter from './SiteFooter.vue'
import ScrollToTop from './ScrollToTop.vue'
import TooltipTag from './TooltipTag.vue'

const { localeIndex } = useData()

const search = ref('')
const majorFilter = ref('all')
const ltsOnly = ref(false)
const sortColumn = ref<'version' | 'date'>('version')
const sortDirection = ref<'asc' | 'desc'>('desc')

function toggleSort(col: 'version' | 'date') {
  if (sortColumn.value === col) {
    sortDirection.value = sortDirection.value === 'asc' ? 'desc' : 'asc'
  } else {
    sortColumn.value = col
    sortDirection.value = 'desc'
  }
}

const filtered = computed(() => {
  let result = releasesIndex.filter(r => {
    if (search.value) {
      const q = search.value.toLowerCase()
      if (!r.version.toLowerCase().includes(q) && !r.release_tag.toLowerCase().includes(q)) return false
    }
    if (majorFilter.value !== 'all' && r.major !== majorFilter.value) return false
    if (ltsOnly.value && !r.lts) return false
    return true
  })

  result.sort((a, b) => {
    const dir = sortDirection.value === 'asc' ? 1 : -1
    if (sortColumn.value === 'version') {
      return a.version.localeCompare(b.version) * dir
    }
    return (new Date(a.created).getTime() - new Date(b.created).getTime()) * dir
  })

  return result
})

const majors = [...new Set(releasesIndex.map(r => r.major))].sort((a, b) => {
  if (a === 'master') return 1
  if (b === 'master') return -1
  return b.localeCompare(a)
})

function fmtDate(iso: string): string {
  if (!iso) return ''
  return new Date(iso).toLocaleDateString(undefined, {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  })
}
</script>

<template>
<div class="space-y-12">
  <header class="space-y-6">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="space-y-1">
        <h1 class="text-4xl font-bold tracking-tight m-0 text-gray-900 dark:text-white">[[releases.title]]</h1>
        <div class="text-sm text-gray-500 font-medium">{{ releasesIndex.length }} [[releases.cataloged]]</div>
      </div>

      <!-- Search -->
      <div class="flex items-center gap-3 w-full max-w-xs group">
        <Icon icon="fa6-solid:magnifying-glass" class="text-gray-400 text-sm group-focus-within:text-blue-500 transition-colors shrink-0" />
        <div class="relative flex-1">
          <input v-model="search" type="text" :placeholder="'[[filter.search]]'"
            class="block w-full px-3 py-2 rounded-md border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#0c0c0e] text-sm placeholder:text-gray-400 focus:border-blue-500 focus:ring-4 focus:ring-blue-500/10 transition-all outline-none dark:text-white" />
          <button v-if="search" @click="search = ''" class="absolute inset-y-0 right-0 pr-3 flex items-center">
            <Icon icon="fa6-solid:xmark" class="text-gray-400 text-xs hover:text-gray-600 dark:hover:text-gray-200 cursor-pointer" />
          </button>
        </div>
      </div>
    </div>

    <!-- Toolbar -->
    <div class="flex flex-wrap items-center gap-8 pt-6 border-t border-gray-100 dark:border-gray-800">
      <!-- Major Version (Radio) -->
      <div class="flex items-center gap-3">
        <span class="text-xs font-bold text-gray-400 uppercase tracking-widest mr-1">Versions</span>
        <div class="flex flex-wrap gap-2">
          <label v-for="m in ['all', ...majors]" :key="m" class="cursor-pointer">
            <input type="radio" name="major" :value="m" v-model="majorFilter" class="sr-only peer" />
            <span class="px-3 py-1 rounded-md text-xs font-bold border transition-all capitalize block
              border-gray-200 dark:border-gray-800 text-gray-600 dark:text-gray-400 bg-white dark:bg-transparent
              peer-checked:bg-blue-600 peer-checked:text-white peer-checked:border-blue-600
              peer-hover:border-blue-500 dark:peer-hover:border-blue-500">
              {{ m === 'all' ? '[[filter.allMajors]]' : m }}
            </span>
          </label>
        </div>
      </div>

      <div class="h-6 w-px bg-gray-200 dark:bg-gray-800 hidden md:block"></div>

      <!-- Toggles -->
      <div class="flex items-center gap-4">
        <label class="cursor-pointer select-none">
          <div @click="ltsOnly = !ltsOnly"
            class="flex items-center gap-2 px-3 py-1 rounded-md text-xs font-bold border transition-all cursor-pointer"
            :class="ltsOnly ? 'bg-green-600 text-white border-green-600' : 'border-gray-200 dark:border-gray-800 text-gray-500 bg-white dark:bg-transparent'">
            <Icon :icon="ltsOnly ? 'fa6-solid:circle-check' : 'fa6-solid:circle'" class="text-xs" />
            [[filter.ltsOnly]]
          </div>
        </label>
      </div>
    </div>
  </header>

  <!-- Releases Table -->
  <div class="min-h-[300px]">
    <div v-if="filtered.length" class="card overflow-x-auto">
      <table class="m-0 border-none">
        <thead>
          <tr>
            <th class="w-[30%] cursor-pointer select-none hover:text-blue-600 transition-colors" @click="toggleSort('version')">
              <span class="inline-flex items-center gap-1">
                [[release.version]]
                <Icon v-if="sortColumn === 'version'" :icon="sortDirection === 'asc' ? 'fa6-solid:arrow-up' : 'fa6-solid:arrow-down'" class="text-xs" />
              </span>
            </th>
            <th class="hidden sm:table-cell cursor-pointer select-none hover:text-blue-600 transition-colors" @click="toggleSort('date')">
              <span class="inline-flex items-center gap-1">
                [[release.releasedOn]]
                <Icon v-if="sortColumn === 'date'" :icon="sortDirection === 'asc' ? 'fa6-solid:arrow-up' : 'fa6-solid:arrow-down'" class="text-xs" />
              </span>
            </th>
            <th class="hidden md:table-cell text-center">[[release.variants]]</th>
            <th class="text-right">[[release.architectures]]</th>
            <th class="text-center w-24"></th>
          </tr>
        </thead>
        <tbody>
          <tr v-for="r in filtered" :key="r.id" class="hover:bg-gray-50/50 dark:hover:bg-gray-800/20 transition-colors">
            <td>
              <div class="flex flex-col gap-1">
                <div class="flex items-center gap-2">
                  <a :href="withBase(`/${localeIndex}/releases/${r.id}`)" class="font-bold text-gray-900 dark:text-white no-underline hover:text-blue-600 transition-colors">{{ r.version }}</a>
                  <TooltipTag :tooltip="'[[release.tooltips.lts]]'"><span v-if="r.lts" class="badge badge-green text-xs px-1.5 py-0">LTS</span></TooltipTag>
                  <TooltipTag :tooltip="'[[release.tooltips.dev]]'"><span v-if="r.ffmpeg_ref.includes('-dev')" class="badge badge-blue text-xs px-1.5 py-0">[[release.master]]</span></TooltipTag>
                </div>
                <TooltipTag :tooltip="'[[release.tooltips.revision]]'"><span class="text-xs font-mono text-gray-400 uppercase tracking-tighter">r{{ r.revision }} • {{ r.release_tag }}</span></TooltipTag>
              </div>
            </td>
            <td class="hidden sm:table-cell text-gray-500 font-medium whitespace-nowrap">{{ fmtDate(r.created) }}</td>
            <td class="hidden md:table-cell text-center font-medium" :class="r.complete ? 'text-green-600' : 'text-amber-600'">
              <TooltipTag :tooltip="'[[release.tooltips.progress]]'"><span>{{ r.variant_count }} / {{ r.total_variants }}</span></TooltipTag>
            </td>
            <td class="text-right">
              <div class="flex flex-wrap justify-end gap-1">
                <TooltipTag v-for="a in r.archs" :key="a" :tooltip="a === 'x64' ? '[[release.tooltips.x64]]' : a === 'x86' ? '[[release.tooltips.x86]]' : a === 'arm64' ? '[[release.tooltips.arm64]]' : '[[release.tooltips.arm32]]'"><span class="badge badge-purple lowercase text-xs px-1.5 py-0">{{ a }}</span></TooltipTag>
              </div>
            </td>
            <td class="text-center">
              <a :href="withBase(`/${localeIndex}/releases/${r.id}`)" class="btn-primary h-7 px-4 text-xs font-bold mx-auto">
                [[variant.download]]
              </a>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div v-else class="text-center py-24 border-2 border-dashed border-gray-100 dark:border-gray-800 rounded-md">
      <Icon icon="fa6-solid:inbox" class="m-auto inline text-4xl text-gray-200 dark:text-gray-800 mb-4" />
      <p class="text-gray-400 font-medium">[[releases.empty]]</p>
      <button @click="search = ''; majorFilter = 'all'; ltsOnly = false" class="text-sm font-bold text-blue-600 hover:underline mt-2">[[releases.reset]]</button>
    </div>
  </div>

  <SiteFooter class="mt-auto" />
  <ScrollToTop />
</div>
</template>
