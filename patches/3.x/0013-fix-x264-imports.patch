Subject: [PATCH] Fix x264 static linking on MSVC by removing X264_API_IMPORTS

---
 libavcodec/libx264.c | 4 ----
 1 file changed, 4 deletions(-)

diff --git a/libavcodec/libx264.c b/libavcodec/libx264.c
index 6b05846..26a561f 100644
--- a/libavcodec/libx264.c
+++ b/libavcodec/libx264.c
@@ -29,10 +29,6 @@
 #include "avcodec.h"
 #include "internal.h"
 
-#if defined(_MSC_VER)
-#define X264_API_IMPORTS 1
-#endif
-
 #include <x264.h>
 #include <float.h>
 #include <math.h>
