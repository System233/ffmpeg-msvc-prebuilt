--- a/build/make/configure.sh
+++ b/build/make/configure.sh
@@ -301,26 +301,54 @@ check_cc() {
 	log check_cc "$@"
 	cat >${TMP_C}
 	log_file ${TMP_C}
-	check_cmd ${CC} ${CFLAGS} "$@" -c -o ${TMP_O} ${TMP_C}
+	if enabled msvs; then
+		local msvc_flags="/c /Fo${TMP_O}"
+		local filtered_args=()
+		for arg in "$@"; do
+			case "$arg" in
+				-Werror) filtered_args+=("/WX") ;;
+				-W*|-f*|-pedantic*) ;;
+				*) filtered_args+=("$arg") ;;
+			esac
+		done
+		check_cmd ${CC} ${CFLAGS} "${filtered_args[@]}" ${msvc_flags} ${TMP_C}
+	else
+		check_cmd ${CC} ${CFLAGS} "$@" -c -o ${TMP_O} ${TMP_C}
+	fi
 }

